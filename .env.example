FLASK_ENV=development
FLASK_DEBUG=true
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
APP_NAME=AI Study App Backend
API_PREFIX=/api

# Firebase Admin configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
# Optional for Render/production. When set, this takes priority over FIREBASE_CREDENTIALS_PATH.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Future JWT configuration
JWT_SECRET_KEY=change-this-before-production
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# Future Cloudinary configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend configuration for registration OTP email
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=AI Study App <onboarding@your-domain.com>

# Future SMS and WhatsApp configuration
SMS_PROVIDER=
SMS_API_KEY=
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=

# Future AI configuration
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
